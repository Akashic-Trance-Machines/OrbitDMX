---
// Reusable screenshot placeholder.
// If `src` is provided it renders a real <img>; otherwise a labelled,
// correctly-sized dashed box that a real screenshot drops into later.
interface Props {
  label: string;
  ratio?: string;        // e.g. "16 / 10"
  src?: string;          // path relative to BASE_URL, e.g. "images/screenshots/scene.png"
  alt?: string;
  hint?: string;         // dimension hint shown in placeholder
}

const { label, ratio = '16 / 10', src, alt, hint } = Astro.props;
const base = import.meta.env.BASE_URL;
const imgSrc = src ? `${base}${src}`.replace(/\/+/g, '/') : undefined;
---

{imgSrc ? (
  <img
    class="ph-img"
    src={imgSrc}
    alt={alt ?? label}
    loading="lazy"
    decoding="async"
    style={`aspect-ratio:${ratio}`}
  />
) : (
  <div class="ph" style={`aspect-ratio:${ratio}`} role="img" aria-label={`${label} (screenshot placeholder)`}>
    <div class="ph-inner">
      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="3" y="4" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" />
        <circle cx="8.5" cy="9" r="1.6" stroke="currentColor" stroke-width="1.5" />
        <path d="M4 16l4.5-4 3 2.5L16 9l4 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="ph-label">{label}</span>
      {hint && <span class="ph-hint">{hint}</span>}
    </div>
  </div>
)}

<style>
  .ph,
  .ph-img {
    width: 100%;
    border-radius: var(--radius);
    background: var(--bg-elevated);
  }

  .ph {
    display: grid;
    place-items: center;
    border: 1.5px dashed var(--border);
    color: var(--text-dim);
  }

  .ph-img {
    object-fit: cover;
    border: 1px solid var(--border);
  }

  .ph-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    text-align: center;
    padding: 1rem;
  }

  .ph-label {
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .ph-hint {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--text-dim);
  }
</style>
