---
import { site } from '../data/site';
import Placeholder from './Placeholder.astro';
---

<section id="hardware" aria-labelledby="hw-title">
  <div class="container">
    <div class="hw-grid">
      <div class="hw-copy reveal">
        <span class="badge">In development</span>
        <h2 id="hw-title">{site.hardwareName}</h2>
        <p class="hw-lead">
          A custom USB-DMX interface <em>and</em> tactile MIDI control surface for
          OrbitDMX — capacitive buttons and sliders with RGB feedback, built on an
          RP2350. It speaks Enttec-Pro-compatible DMX over USB and acts as a
          configurable MIDI controller, so it works as a plug-and-play companion to
          the app.
        </p>

        <div class="hw-highlight">
          <h3>Standalone mode</h3>
          <p>
            Push a full show — scenes, playlists, colour generators, FX and control
            bindings — from OrbitDMX onto the device, unplug the computer, and the
            {site.hardwareShort} runs the show on its own.
          </p>
        </div>

        <p class="hw-note">
          The firmware is open source. The hardware design itself is not published.
        </p>

        <div class="hw-cta">
          <a class="btn btn-primary" href={site.firmwareRepo} target="_blank" rel="noopener">
            Follow development on GitHub
          </a>
          <a class="btn btn-ghost" href={site.notifyMailto}>Notify me</a>
        </div>
      </div>

      <div class="hw-shot reveal">
        <Placeholder
          label="OrbitBridgeDeck — hardware render"
          ratio="4 / 3"
          hint="render / photo placeholder"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hw-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }

  @media (min-width: 920px) {
    .hw-grid { grid-template-columns: 1.1fr 0.9fr; }
  }

  .badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--warn);
    background: rgba(255, 180, 84, 0.12);
    border: 1px solid rgba(255, 180, 84, 0.35);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  .hw-copy h2 { font-size: clamp(1.85rem, 4vw, 2.6rem); }

  .hw-lead {
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .hw-highlight {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    margin: 1.5rem 0;
  }

  .hw-highlight h3 {
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
    color: var(--text);
  }

  .hw-highlight p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .hw-note {
    font-size: 0.9rem;
    color: var(--text-dim);
  }

  .hw-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }
</style>
