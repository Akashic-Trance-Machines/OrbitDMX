---
import { site } from '../data/site';
import Placeholder from './Placeholder.astro';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container">
    <div class="hero-copy reveal">
      <h1 id="hero-title">
        Open-source stage lighting<br />
        control that <span class="grad-text">just works.</span>
      </h1>
      <p class="hero-sub">{site.subTagline}</p>

      <div class="hero-cta">
        <a class="btn btn-primary" href="#download">Download free</a>
        <a class="btn btn-ghost" href={site.repo} target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <p class="trust-row">{site.trustRow}</p>
    </div>

    <div class="hero-shot reveal">
      <Placeholder
        label="OrbitDMX app — main view"
        ratio="16 / 10"
        hint="1600 × 1000 · public/images/screenshots/"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3.5rem, 9vw, 6.5rem) clamp(3rem, 7vw, 5rem);
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: -20% 0 auto 0;
    height: 70%;
    background: var(--accent-glow);
    pointer-events: none;
  }

  .hero .container {
    position: relative;
    display: grid;
    gap: clamp(2.5rem, 5vw, 4rem);
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 1.1rem;
  }

  .hero-sub {
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: var(--text-muted);
    max-width: 38rem;
    margin-bottom: 1.75rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .trust-row {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin: 0;
  }

  .hero-shot { width: 100%; }

  /* Two-column on wide screens */
  @media (min-width: 920px) {
    .hero .container {
      grid-template-columns: 1.05fr 1fr;
      align-items: center;
    }
  }
</style>
