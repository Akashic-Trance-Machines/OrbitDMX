---
import type { Feature } from '../data/features';
interface Props extends Feature {}
const { icon, title, description } = Astro.props;

// Inline line-style icons keyed by feature. Stroke uses currentColor (accent-tinted).
const icons: Record<string, string> = {
  rooms: '<rect x="3" y="3" width="8" height="8" rx="1.5"/><rect x="13" y="3" width="8" height="8" rx="1.5"/><rect x="3" y="13" width="8" height="8" rx="1.5"/><rect x="13" y="13" width="8" height="8" rx="1.5"/>',
  playlist: '<path d="M4 6h11M4 12h11M4 18h7"/><circle cx="18.5" cy="16.5" r="2.5"/><path d="M21 16.5V9l-2 .8"/>',
  palette: '<path d="M12 3a9 9 0 1 0 0 18c1 0 1.5-.8 1.5-1.6 0-.5-.3-.9-.3-1.4 0-.6.5-1 1.1-1H16a5 5 0 0 0 5-5c0-4.4-4-8-9-8Z"/><circle cx="7.5" cy="11.5" r="1"/><circle cx="9.5" cy="7.5" r="1"/><circle cx="14.5" cy="7.5" r="1"/><circle cx="16.5" cy="11.5" r="1"/>',
  fx: '<path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/>',
  controls: '<path d="M4 6h16M4 12h16M4 18h16"/><circle cx="9" cy="6" r="2"/><circle cx="15" cy="12" r="2"/><circle cx="7" cy="18" r="2"/>',
  midi: '<rect x="3" y="9" width="18" height="11" rx="2"/><path d="M7 20v-6M12 20v-6M17 20v-6M3 9l3-5h12l3 5"/>',
  output: '<path d="M3 12h4l2 6 4-14 2 8h6"/>',
  library: '<path d="M5 4h4v16H5zM10 4h4v16h-4z"/><path d="m15.5 4.5 3.8 1 3.3 14.5-3.8-1Z"/>',
  open: '<path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="9"/>',
};

const path = icons[icon] ?? icons.open;
---

<article class="card reveal">
  <span class="card-icon" aria-hidden="true">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={path} />
  </span>
  <h3>{title}</h3>
  <p>{description}</p>
</article>

<style>
  .card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    transition: transform 0.18s ease, border-color 0.18s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
  }

  .card-icon {
    display: inline-grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 11px;
    margin-bottom: 1rem;
    color: var(--accent-2);
    background: rgba(33, 212, 253, 0.1);
    border: 1px solid rgba(108, 92, 255, 0.25);
  }

  .card h3 {
    font-size: 1.12rem;
    margin-bottom: 0.4rem;
  }

  .card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .card:hover { transform: none; transition: border-color 0.18s ease; }
  }
</style>
