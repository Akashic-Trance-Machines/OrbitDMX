---
import { site } from '../data/site';
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="brand" href={base} aria-label={`${site.name} home`}>
        <img src={`${base}favicon.svg`} alt="" width="24" height="24" />
        <span>{site.name}</span>
      </a>
      <p>By {site.org} · © {site.year} · MIT License</p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <a href={site.repo} target="_blank" rel="noopener">GitHub — app</a>
      <a href={site.firmwareRepo} target="_blank" rel="noopener">GitHub — firmware</a>
      <a href={site.releasesAll} target="_blank" rel="noopener">Releases</a>
      <a href={site.license} target="_blank" rel="noopener">License</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding-block: 2.5rem;
    background: var(--bg);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
  }

  .footer .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
  }

  .footer-brand p {
    margin: 0.5rem 0 0;
    color: var(--text-dim);
    font-size: 0.88rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.15s ease;
  }

  .footer-links a:hover { color: var(--text); }
</style>
