{
  "name": "orbit-dmx",
  "productName": "OrbitDMX",
  "version": "1.4.0",
  "description": "A modern, open-source stage lighting DMX controller",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "scrape:ayra": "ts-node scripts/scrape-ayra.ts",
    "parse:local": "ts-node scripts/parse-local.ts",
    "postinstall": "patch-package && (cd node_modules/@serialport/bindings-cpp && npx node-gyp rebuild --target=$(node -e \"process.stdout.write(require('../../electron/package.json').version)\") --arch=arm64 --dist-url=https://electronjs.org/headers --runtime=electron && cp build/Release/bindings.node bin/darwin-arm64-145/bindings-cpp.node)"
  },
  "keywords": [],
  "author": {
    "name": "Toon Nelissen",
    "email": "toon@appsaloon.be"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@google/generative-ai": "^0.24.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "41.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "patch-package": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^24.42.0",
    "ts-node": "^10.9.2",
    "typescript": "~4.5.4",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "serialport": "^13.0.0",
    "usb": "^2.17.0",
    "zustand": "^5.0.12"
  }
}
